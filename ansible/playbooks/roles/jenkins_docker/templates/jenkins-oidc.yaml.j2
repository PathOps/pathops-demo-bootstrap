jenkins:
  systemMessage: "PathOps demo Jenkins"

  securityRealm:
    oic:
      clientId: "{{ jenkins_oidc_client_id }}"
      clientSecret: "{{ jenkins_oidc_client_secret }}"
      serverConfiguration:
        wellKnown:
          wellKnownOpenIDConfigurationUrl: "{{ jenkins_keycloak_issuer }}/.well-known/openid-configuration"
          scopesOverride: "{{ jenkins_oidc_scopes | join(' ') }}"
      userNameField: "preferred_username"
      fullNameFieldName: "name"
      emailFieldName: "email"

  authorizationStrategy:
    loggedInUsersCanDoAnything:
      allowAnonymousRead: false

unclassified:
  location:
    url: "{{ jenkins_root_url }}"